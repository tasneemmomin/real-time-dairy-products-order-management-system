# =============================================
# DairyOS Pro - Server Environment Variables
# =============================================
# Copy this file to .env and fill in the values.
# NEVER commit the actual .env file!

# ------ Database ------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/dairyospro?retryWrites=true&w=majority

# ------ Authentication ------
JWT_SECRET=your_very_strong_random_secret_here_min_32_chars

# ------ Server ------
PORT=5000
NODE_ENV=development

# ------ Admin Credentials ------
# These are the fixed admin login credentials.
# Change these in production!
ADMIN_EMAIL=vasantdadaagency816@gmail.com
ADMIN_PASSWORD=vasantdada123
ADMIN_NAME=Kedar Patil

# ------ Payment ------
# UPI ID for QR code generation
UPI_ID=9975882125@okbizaxis

# ------ Notifications ------
# WhatsApp number for owner notifications (Indian format: 91XXXXXXXXXX)
OWNER_WHATSAPP=918766997752

# ------ CORS ------
# Set this to your Vercel frontend URL in production
CLIENT_URL=https://dairy-ospro.vercel.app
